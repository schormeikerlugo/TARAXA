---
---

<section id="hero" class="hero">

  <!-- Grid overlay -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- Scan line on load -->
  <div class="hero-scan" aria-hidden="true"></div>

  <!-- Background massive wordmark -->
  <div class="hero-wordmark" aria-hidden="true">TARAXA</div>

  <!-- Diagonal split image panel -->
  <div class="hero-panel-right" aria-hidden="true">
    <video
      class="hero-panel-video"
      autoplay muted loop playsinline
      poster="/images/AdobeStock_416523142.jpeg"
    >
      <source src="/videos/AdobeStock_178069843.mp4" type="video/mp4" />
    </video>
    <div class="hero-panel-tint"></div>
  </div>

  <!-- Main content -->
  <div class="hero-body container">
    <div class="hero-left">

      <div class="hero-stamp">
        <span class="mono stamp-text">Est. 1988</span>
        <span class="stamp-dot"></span>
        <span class="mono stamp-text">GUMEX Poland</span>
      </div>

      <h1 class="hero-h1">
        <span class="h1-line h1-line-1">
          <span class="h1-word">Custom</span>
        </span>
        <span class="h1-line h1-line-2">
          <span class="h1-word italic-word">Rubber</span>
        </span>
        <span class="h1-line h1-line-3">
          <span class="h1-word">Engineering</span>
        </span>
      </h1>

      <div class="hero-rule-group">
        <div class="hero-rule"></div>
        <p class="hero-descriptor mono">
          Precision-moulded rubber components ·<br/>
          EU manufacturing · Worldwide delivery
        </p>
      </div>

      <div class="hero-cta">
        <a href="#contact" class="cta-primary">
          <span class="cta-inner">
            <span class="cta-text">Request a Quote</span>
            <span class="cta-icon" aria-hidden="true">↗</span>
          </span>
          <span class="cta-bg-fill"></span>
        </a>
        <a href="#capabilities" class="cta-secondary mono">
          See capabilities <span>—</span>
        </a>
      </div>

    </div>
  </div>

  <!-- Bottom stats rail -->
  <div class="hero-rail">
    <div class="rail-inner container">
      <div class="rail-stat">
        <span class="rail-num">35<sup>+</sup></span>
        <span class="rail-label mono">Years</span>
      </div>
      <div class="rail-sep" aria-hidden="true"></div>
      <div class="rail-stat">
        <span class="rail-num">40<sup>+</sup></span>
        <span class="rail-label mono">Countries</span>
      </div>
      <div class="rail-sep" aria-hidden="true"></div>
      <div class="rail-stat">
        <span class="rail-num">7</span>
        <span class="rail-label mono">Compounds</span>
      </div>
      <div class="rail-sep" aria-hidden="true"></div>
      <div class="rail-stat">
        <span class="rail-num">ISO</span>
        <span class="rail-label mono">9001</span>
      </div>
      <div class="rail-tagline mono">
        Made in Poland · Shipped Worldwide
      </div>
      <div class="rail-scroll-hint">
        <div class="scroll-track">
          <div class="scroll-thumb"></div>
        </div>
        <span class="mono">Scroll</span>
      </div>
    </div>
  </div>

  <!-- Corner cross marks -->
  <div class="cross-mark cm-tl" aria-hidden="true"></div>
  <div class="cross-mark cm-br" aria-hidden="true"></div>

</section>

<!-- Dandelion seeds drifting upward -->
<div class="hero-seeds" aria-hidden="true">
  <svg class="seed s1" viewBox="0 0 20 60" xmlns="http://www.w3.org/2000/svg">
    <circle cx="10" cy="8" r="3" fill="none" stroke="currentColor" stroke-width="1"/>
    <line x1="10" y1="11" x2="10" y2="60" stroke="currentColor" stroke-width="0.8" opacity="0.6"/>
    <line x1="7" y1="6" x2="4" y2="2" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
    <line x1="13" y1="6" x2="16" y2="2" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
    <line x1="10" y1="5" x2="10" y2="1" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
  </svg>
  <svg class="seed s2" viewBox="0 0 20 60" xmlns="http://www.w3.org/2000/svg">
    <circle cx="10" cy="8" r="3" fill="none" stroke="currentColor" stroke-width="1"/>
    <line x1="10" y1="11" x2="10" y2="60" stroke="currentColor" stroke-width="0.8" opacity="0.6"/>
    <line x1="7" y1="6" x2="4" y2="2" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
    <line x1="13" y1="6" x2="16" y2="2" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
    <line x1="10" y1="5" x2="10" y2="1" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
  </svg>
  <svg class="seed s3" viewBox="0 0 20 60" xmlns="http://www.w3.org/2000/svg">
    <circle cx="10" cy="8" r="3" fill="none" stroke="currentColor" stroke-width="1"/>
    <line x1="10" y1="11" x2="10" y2="60" stroke="currentColor" stroke-width="0.8" opacity="0.6"/>
    <line x1="7" y1="6" x2="4" y2="2" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
    <line x1="13" y1="6" x2="16" y2="2" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
  </svg>
  <svg class="seed s4" viewBox="0 0 20 60" xmlns="http://www.w3.org/2000/svg">
    <circle cx="10" cy="8" r="3" fill="none" stroke="currentColor" stroke-width="1"/>
    <line x1="10" y1="11" x2="10" y2="60" stroke="currentColor" stroke-width="0.8" opacity="0.6"/>
    <line x1="7" y1="6" x2="4" y2="2" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
    <line x1="13" y1="6" x2="16" y2="2" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
    <line x1="10" y1="5" x2="10" y2="1" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
  </svg>
  <svg class="seed s5" viewBox="0 0 20 60" xmlns="http://www.w3.org/2000/svg">
    <circle cx="10" cy="8" r="3" fill="none" stroke="currentColor" stroke-width="1"/>
    <line x1="10" y1="11" x2="10" y2="60" stroke="currentColor" stroke-width="0.8" opacity="0.6"/>
    <line x1="7" y1="6" x2="4" y2="2" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
    <line x1="13" y1="6" x2="16" y2="2" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
  </svg>
  <svg class="seed s6" viewBox="0 0 20 60" xmlns="http://www.w3.org/2000/svg">
    <circle cx="10" cy="8" r="3" fill="none" stroke="currentColor" stroke-width="1"/>
    <line x1="10" y1="11" x2="10" y2="60" stroke="currentColor" stroke-width="0.8" opacity="0.6"/>
    <line x1="7" y1="6" x2="4" y2="2" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
    <line x1="13" y1="6" x2="16" y2="2" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
    <line x1="10" y1="5" x2="10" y2="1" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
  </svg>
</div>

<style>
  /* ────────────────────────────────────────────
     HERO SHELL
  ──────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    background: var(--ink);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* ── Blueprint grid ── */
  .hero-grid {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(201,168,76,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(201,168,76,0.04) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: linear-gradient(to bottom, transparent, rgba(0,0,0,0.6) 20%, rgba(0,0,0,0.6) 80%, transparent);
  }

  /* ── Scan animation ── */
  .hero-scan {
    position: absolute;
    top: -4px;
    left: 0;
    right: 0;
    height: 4px;
    z-index: 20;
    background: linear-gradient(90deg, transparent, var(--rust) 40%, var(--gold) 60%, transparent);
    animation: scan-down 1.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    pointer-events: none;
  }

  @keyframes scan-down {
    0%   { top: -4px; opacity: 1; }
    80%  { opacity: 1; }
    100% { top: 100%; opacity: 0; }
  }

  /* ── Background wordmark ── */
  .hero-wordmark {
    position: absolute;
    z-index: 2;
    bottom: -0.15em;
    left: -0.02em;
    font-family: var(--font-display);
    font-size: clamp(14rem, 28vw, 32rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(245,240,232,0.04);
    text-stroke: 1px rgba(245,240,232,0.04);
    pointer-events: none;
    user-select: none;
    animation: wordmark-in 1.8s 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes wordmark-in {
    from { opacity: 0; transform: translateY(40px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Right diagonal panel ── */
  .hero-panel-right {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 52%;
    clip-path: polygon(12% 0, 100% 0, 100% 100%, 0% 100%);
    z-index: 3;
  }

  .hero-panel-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    opacity: 0;
    animation: panel-reveal 1.2s 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-panel-tint {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      var(--ink) 0%,
      rgba(26,26,24,0.55) 30%,
      rgba(74,82,64,0.2) 70%,
      rgba(26,26,24,0.4) 100%
    );
  }

  @keyframes panel-reveal {
    from { opacity: 0; transform: scale(1.06); }
    to   { opacity: 0.7; transform: scale(1); }
  }

  /* ── Coordinate badge ── */
  .hero-coord {
    position: absolute;
    top: 2.5rem;
    right: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.15rem;
    opacity: 0;
    animation: fade-up 0.8s 1.6s ease both;
  }

  .coord-label {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: var(--gold);
    text-transform: uppercase;
  }

  .coord-sub {
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    color: rgba(245,240,232,0.4);
    text-transform: uppercase;
  }

  /* ── Main body ── */
  .hero-body {
    position: relative;
    z-index: 10;
    flex: 1;
    display: flex;
    align-items: center;
    padding-top: 9rem;
    padding-bottom: 5rem;
  }

  .hero-left {
    max-width: 580px;
  }

  /* ── Stamp ── */
  .hero-stamp {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 2.2rem;
    opacity: 0;
    animation: fade-up 0.7s 1s ease both;
  }

  .stamp-text {
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.4);
  }

  .stamp-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--rust);
    flex-shrink: 0;
    animation: dot-pulse 2.4s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(200,75,47,0.5); }
    50%       { opacity: 0.7; box-shadow: 0 0 0 5px rgba(200,75,47,0); }
  }

  /* ── H1 ── */
  .hero-h1 {
    display: flex;
    flex-direction: column;
    font-family: var(--font-display);
    font-size: clamp(3.4rem, 7vw, 7.2rem);
    font-weight: 300;
    line-height: 0.92;
    letter-spacing: -0.03em;
    margin-bottom: 2.5rem;
    gap: 0.04em;
  }

  .h1-line {
    overflow: hidden;
    display: block;
    padding-bottom: 0.15em;
    margin-bottom: -0.15em;
  }

  .h1-word {
    display: block;
    color: var(--bone);
    opacity: 0;
    transform: translateY(105%);
  }

  .h1-line-1 .h1-word {
    color: rgba(245,240,232,0.45);
    animation: word-rise 0.9s 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .h1-line-2 .h1-word {
    color: var(--gold);
    animation: word-rise 0.9s 1.05s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .h1-line-3 .h1-word {
    animation: word-rise 0.9s 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .italic-word { font-style: italic; }

  @keyframes word-rise {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Rule + descriptor ── */
  .hero-rule-group {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    margin-bottom: 2.75rem;
    opacity: 0;
    animation: fade-up 0.8s 1.5s ease both;
  }

  .hero-rule {
    width: 2px;
    min-height: 48px;
    background: linear-gradient(to bottom, var(--rust), transparent);
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .hero-descriptor {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.45);
    line-height: 2;
  }

  /* ── CTA ── */
  .hero-cta {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fade-up 0.8s 1.7s ease both;
  }

  .cta-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 0.95rem 2rem;
    overflow: hidden;
    text-decoration: none;
    border: 1px solid var(--rust);
  }

  .cta-inner {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--bone);
    transition: color 0.35s;
  }

  .cta-bg-fill {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: var(--rust);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cta-primary:hover .cta-bg-fill { transform: scaleX(1); }

  .cta-icon {
    font-size: 1.1rem;
    transition: transform 0.3s;
  }

  .cta-primary:hover .cta-icon { transform: translate(3px, -3px); }

  .cta-secondary {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.45);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: color 0.3s;
  }

  .cta-secondary span {
    display: inline-block;
    transition: transform 0.3s;
  }

  .cta-secondary:hover { color: var(--bone); }
  .cta-secondary:hover span { transform: translateX(6px); }

  /* ── Bottom stats rail ── */
  .hero-rail {
    position: relative;
    z-index: 10;
    border-top: 1px solid rgba(245,240,232,0.07);
    background: rgba(26,26,24,0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    opacity: 0;
    animation: fade-up 0.6s 2s ease both;
  }

  .rail-inner {
    display: flex;
    align-items: center;
    gap: 0;
    padding-block: 1.1rem;
  }

  .rail-stat {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    padding-inline: 2rem;
  }

  .rail-stat:first-child { padding-left: 0; }

  .rail-num {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--bone);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .rail-num sup {
    font-size: 0.65em;
    color: var(--rust);
  }

  .rail-label {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.35);
  }

  .rail-sep {
    width: 1px;
    height: 1.6rem;
    background: rgba(245,240,232,0.08);
    flex-shrink: 0;
  }

  .rail-tagline {
    flex: 1;
    text-align: center;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.25);
  }

  .rail-scroll-hint {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.25);
    flex-shrink: 0;
  }

  .scroll-track {
    width: 28px;
    height: 1px;
    background: rgba(245,240,232,0.12);
    position: relative;
    overflow: hidden;
  }

  .scroll-thumb {
    position: absolute;
    left: -100%;
    top: 0;
    width: 100%;
    height: 100%;
    background: var(--gold);
    animation: scroll-sweep 2.4s ease-in-out infinite;
  }

  @keyframes scroll-sweep {
    0%   { left: -100%; }
    100% { left: 100%; }
  }

  /* ── Corner cross marks ── */
  .cross-mark {
    position: absolute;
    z-index: 5;
    width: 20px;
    height: 20px;
    pointer-events: none;
  }

  .cross-mark::before,
  .cross-mark::after {
    content: '';
    position: absolute;
    background: rgba(201,168,76,0.3);
  }

  .cross-mark::before { width: 100%; height: 1px; top: 50%; transform: translateY(-50%); }
  .cross-mark::after  { height: 100%; width: 1px; left: 50%; transform: translateX(-50%); }

  .cm-tl { top: 2rem; left: 2rem; }
  .cm-br { bottom: 5.5rem; right: 2rem; }

  /* ── Floating dandelion seeds ── */
  .hero-seeds {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    overflow: hidden;
  }

  .seed {
    position: absolute;
    width: 18px;
    height: 54px;
    color: var(--gold);
    opacity: 0;
  }

  .s1 { bottom: 30%; left: 22%; animation: seed-drift 14s 2s  linear infinite; }
  .s2 { bottom: 20%; left: 10%; animation: seed-drift 18s 4s  linear infinite; }
  .s3 { bottom: 45%; left: 35%; animation: seed-drift 11s 0.5s linear infinite; }
  .s4 { bottom: 35%; left: 6%;  animation: seed-drift 16s 3s  linear infinite; }
  .s5 { bottom: 25%; left: 28%; animation: seed-drift 13s 6s  linear infinite; }
  .s6 { bottom: 55%; left: 16%; animation: seed-drift 20s 1s  linear infinite; }

  @keyframes seed-drift {
    0%   { opacity: 0; transform: translate(0, 0) rotate(5deg); }
    8%   { opacity: 0.55; }
    85%  { opacity: 0.25; }
    100% { opacity: 0; transform: translate(-60px, -380px) rotate(-15deg); }
  }

  /* ── Shared util ── */
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero-panel-right {
      width: 100%;
      clip-path: none;
      opacity: 0.15;
    }

    .hero-panel-tint {
      background: rgba(26,26,24,0.7);
    }

    .hero-coord { display: none; }
    .rail-tagline { display: none; }
    .rail-scroll-hint { display: none; }
    .hero-wordmark { font-size: clamp(10rem, 30vw, 16rem); }
    .cross-mark { display: none; }
  }

  @media (max-width: 480px) {
    .hero-body { padding-top: 7rem; }
    .rail-stat { padding-inline: 1rem; }
    .hero-seeds { display: none; }
  }
</style>
