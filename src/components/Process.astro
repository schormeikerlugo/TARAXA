---
const steps = [
  {
    num: '01',
    phase: 'Brief',
    title: 'Tell us your challenge',
    description: 'Share your application requirements — material conditions, geometry, temperature range, production volume, and any relevant standards or certifications needed.',
    duration: '1–2 days',
    deliverable: 'Intake form review',
  },
  {
    num: '02',
    phase: 'Advise',
    title: 'We engineer the solution',
    description: 'Our engineers select the optimal rubber compound, recommend geometry improvements, and propose the most efficient moulding process for your volumes and tolerances.',
    duration: '3–5 days',
    deliverable: 'Technical proposal',
  },
  {
    num: '03',
    phase: 'Quote',
    title: 'Transparent pricing',
    description: 'Detailed quotation covering tooling investment, unit price at volume, lead time, packaging, and logistics. No hidden costs — every line item is explained.',
    duration: '2–3 days',
    deliverable: 'Formal quotation',
  },
  {
    num: '04',
    phase: 'Prototype',
    title: 'First parts in your hands',
    description: 'Rapid prototype tooling or 3D-printed surrogate parts for fit and function testing. Physical samples shipped for your approval before full production commences.',
    duration: '1–3 weeks',
    deliverable: 'Physical samples',
  },
  {
    num: '05',
    phase: 'Produce & Ship',
    title: 'Scale with confidence',
    description: 'Full production moulding with 100% dimensional inspection and test certificates. We pack, label, and ship — directly to your facility or 3PL warehouse anywhere in the world.',
    duration: '2–6 weeks',
    deliverable: 'Certified delivery',
  },
];
---

<section id="process" class="process">

  <!-- Header row -->
  <div class="process-head container">
    <div class="process-head-left">
      <p class="sec-index sec-index--light reveal">03 — The Process</p>
      <h2 class="sec-title sec-title--light process-title reveal reveal-delay-1">
        From brief to<br/>
        <em>production.</em>
      </h2>
    </div>
    <p class="process-lead reveal reveal-delay-2">
      Five clear steps. Transparent communication at every stage.
      No surprises — just precision engineering and reliable delivery.
    </p>
  </div>

  <!-- Steps list -->
  <div class="process-list" role="list">
    {steps.map((step, i) => (
      <article
        class={`process-row reveal reveal-delay-${Math.min(i + 1, 5)}`}
        role="listitem"
        data-index={i}
      >
        <div class="process-row-inner container">

          <!-- Number -->
          <span class="process-num" aria-hidden="true">{step.num}</span>

          <!-- Phase tag -->
          <span class="process-phase mono">{step.phase}</span>

          <!-- Title + description -->
          <div class="process-body">
            <h3 class="process-row-title">{step.title}</h3>
            <p class="process-row-desc">{step.description}</p>
          </div>

          <!-- Meta -->
          <div class="process-meta">
            <div class="process-meta-item">
              <span class="meta-label mono">Duration</span>
              <span class="meta-val mono">{step.duration}</span>
            </div>
            <div class="process-meta-item">
              <span class="meta-label mono">Deliverable</span>
              <span class="meta-val mono">{step.deliverable}</span>
            </div>
          </div>

          <!-- Arrow -->
          <span class="process-arrow" aria-hidden="true">↗</span>

        </div>
      </article>
    ))}
  </div>

  <!-- Footer note -->
  <div class="process-foot container reveal">
    <span class="mono foot-label">Total lead time</span>
    <span class="foot-range">4 – 10 weeks</span>
    <span class="foot-note mono">from first contact to first production delivery · Rush prototyping available</span>
  </div>

</section>

<style>
  .process {
    background: var(--ink);
    padding-block: clamp(5rem, 10vw, 9rem);
    position: relative;
    overflow: hidden;
  }

  /* Dot pattern overlay */
  .process::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(201,168,76,0.12) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }

  /* ── Header ── */
  .process-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: end;
    padding-bottom: clamp(3rem, 6vw, 5rem);
    border-bottom: 1px solid rgba(245,240,232,0.06);
    margin-bottom: 0;
  }

  .process-lead {
    font-size: clamp(0.95rem, 1.2vw, 1.05rem);
    color: rgba(245,240,232,0.45);
    line-height: 1.75;
    max-width: 420px;
    align-self: end;
  }

  /* ── Rows ── */
  .process-list {
    position: relative;
  }

  .process-row {
    position: relative;
    border-bottom: 1px solid rgba(245,240,232,0.06);
    cursor: default;
    transition: background 0.4s ease;
  }

  /* Animated left accent bar */
  .process-row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--rust);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.45s var(--ease-out-expo);
  }

  .process-row:hover::before {
    transform: scaleY(1);
  }

  .process-row:hover {
    background: rgba(245,240,232,0.02);
  }

  .process-row-inner {
    display: grid;
    grid-template-columns: 5rem 9rem 1fr auto 2.5rem;
    align-items: center;
    gap: 2.5rem;
    padding-block: 2.25rem;
  }

  /* ── Number ── */
  .process-num {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3.5rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.03em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(245,240,232,0.15);
    transition: -webkit-text-stroke 0.4s ease, color 0.4s ease;
    flex-shrink: 0;
  }

  .process-row:hover .process-num {
    color: var(--rust);
    -webkit-text-stroke: 1px var(--rust);
  }

  /* ── Phase tag ── */
  .process-phase {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.3);
    transition: color 0.4s ease;
    flex-shrink: 0;
  }

  .process-row:hover .process-phase {
    color: var(--gold);
  }

  /* ── Body ── */
  .process-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .process-row-title {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.8vw, 1.6rem);
    font-weight: 300;
    color: rgba(245,240,232,0.85);
    letter-spacing: -0.015em;
    line-height: 1.2;
    transition: color 0.3s ease;
  }

  .process-row:hover .process-row-title {
    color: var(--bone);
  }

  .process-row-desc {
    font-size: 0.82rem;
    color: rgba(245,240,232,0.3);
    line-height: 1.7;
    max-width: 480px;
    /* Hidden by default, revealed on hover */
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.5s var(--ease-out-expo), opacity 0.4s ease;
  }

  .process-row:hover .process-row-desc,
  .process-row.expanded .process-row-desc {
    max-height: 120px;
    opacity: 1;
  }

  /* ── Meta ── */
  .process-meta {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    text-align: right;
    flex-shrink: 0;
  }

  .process-meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .meta-label {
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.2);
  }

  .meta-val {
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: rgba(245,240,232,0.5);
    transition: color 0.3s ease;
  }

  .process-row:hover .meta-val {
    color: var(--gold);
  }

  /* ── Arrow ── */
  .process-arrow {
    font-size: 1.1rem;
    color: rgba(245,240,232,0.15);
    transition: color 0.3s ease, transform 0.3s ease;
    display: block;
    text-align: right;
  }

  .process-row:hover .process-arrow {
    color: var(--rust);
    transform: translate(3px, -3px);
  }

  /* ── Footer note ── */
  .process-foot {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-top: 2.5rem;
    flex-wrap: wrap;
  }

  .foot-label {
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.25);
  }

  .foot-range {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 300;
    color: var(--bone);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .foot-note {
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    color: rgba(245,240,232,0.2);
    max-width: 340px;
    line-height: 1.7;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .process-row-inner {
      grid-template-columns: 4rem 7rem 1fr auto 2rem;
      gap: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .process-head {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .process-row-inner {
      grid-template-columns: 3rem 1fr 2rem;
      grid-template-rows: auto auto;
      gap: 1rem;
      padding-block: 1.75rem;
    }

    .process-phase {
      display: none;
    }

    .process-body {
      grid-column: 2;
      grid-row: 1 / 3;
    }

    .process-meta {
      display: none;
    }

    .process-arrow {
      grid-column: 3;
      grid-row: 1;
    }

    .process-row-desc {
      max-height: none;
      opacity: 1;
    }
  }
</style>

<script>
  // Expand first row by default
  const rows = document.querySelectorAll('.process-row');
  if (rows.length) rows[0].classList.add('expanded');

  rows.forEach(row => {
    row.addEventListener('mouseenter', () => {
      rows.forEach(r => r.classList.remove('expanded'));
      row.classList.add('expanded');
    });
  });
</script>
