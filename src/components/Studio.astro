<style>
  .studio {
    background: var(--light);
    padding-top: clamp(5rem, 10vw, 9rem);
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  /* Subtle background botanical */
  .studio::before {
    content: "";
    position: absolute;
    top: -10%;
    right: -8%;
    width: 600px;
    height: 600px;
    background: radial-gradient(
      circle,
      rgba(201, 168, 76, 0.06) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  /* Header */
  .studio-header {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 5rem;
  }

  .studio-title {
    font-family: var(--font-display);
    color: var(--ink);
  }

  .studio-title em {
    color: var(--rust);
    font-style: italic;
  }

  /* Grid */
  .studio-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: start;
    margin-bottom: 5rem;
  }

  /* Story */
  .studio-story-block {
    margin-bottom: 1.75rem;
  }

  .studio-story-block strong {
    color: var(--ink);
    font-weight: 600;
  }
  .studio-story-block em {
    color: var(--moss);
    font-style: italic;
  }

  .studio-lead {
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.75;
    color: var(--ink);
    font-weight: 400;
  }

  /* Facts */
  .studio-facts {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 2.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--ink-10);
  }

  .studio-fact {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .studio-fact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background: var(--moss-soft);
    color: var(--moss);
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .studio-fact strong {
    display: block;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--ink);
    margin-bottom: 0.25rem;
  }

  .studio-fact .body-sm {
    color: var(--ink-60);
  }

  /* Visual */
  .studio-visual {
    position: relative;
  }

  .studio-img-main {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(26, 26, 24, 0.14);
  }

  .studio-img-main img {
    width: 100%;
    height: 520px;
    object-fit: cover;
    transition: transform 0.8s var(--ease-out-expo);
  }

  .studio-img-main:hover img {
    transform: scale(1.03);
  }

  .studio-img-badge {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.1rem;
    background: rgba(26, 26, 24, 0.82);
    backdrop-filter: blur(12px);
    border-radius: var(--radius-md);
    padding: 0.875rem 1.25rem;
    border: 1px solid rgba(245, 240, 232, 0.1);
  }

  .studio-img-badge .mono {
    color: rgba(245, 240, 232, 0.5);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .studio-badge-year {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--gold);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .studio-img-secondary {
    position: absolute;
    bottom: -2.5rem;
    right: -1.5rem;
    width: 220px;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 16px 50px rgba(26, 26, 24, 0.2);
    border: 3px solid var(--light);
  }

  .studio-img-secondary img {
    width: 100%;
    height: 170px;
    object-fit: cover;
    transition: transform 0.8s var(--ease-out-expo);
  }

  .studio-img-secondary:hover img {
    transform: scale(1.04);
  }

  /* Etymology */
  .studio-etymology {
    margin-top: 4.5rem;
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.5rem;
    background: rgba(201, 168, 76, 0.13);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(201, 168, 76, 0.35);
    box-shadow:
      inset 0 1px 0 rgba(201, 168, 76, 0.2),
      0 8px 32px rgba(201, 168, 76, 0.1);
  }

  .studio-etymology-plant {
    flex-shrink: 0;
  }

  .studio-etymology-word {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 300;
    font-style: italic;
    color: var(--moss);
    margin-bottom: 0.5rem;
  }

  /* Stats bar */
  .studio-stats {
    background: var(--ink);
    padding-block: 2.5rem;
    margin-top: auto;
    border-bottom: 1px solid rgba(245, 240, 232, 0.08);
  }

  .studio-stats-inner {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .sstat {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding-inline: 2rem;
    flex-shrink: 0;
  }

  .sstat:first-child {
    padding-left: 0;
  }

  .sstat svg {
    flex-shrink: 0;
    opacity: 0.85;
  }

  .sstat-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .sstat-title {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--bone);
    line-height: 1;
  }

  .sstat-label {
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.3);
    line-height: 1;
  }

  .sstat-divider {
    width: 1px;
    height: 2rem;
    background: rgba(245, 240, 232, 0.08);
    flex-shrink: 0;
  }

  /* Dandelion motif */
  .sstat-motif {
