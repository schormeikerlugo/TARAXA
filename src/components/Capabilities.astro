---
const capabilities = [
  {
    id: "01",
    title: "Compression & Injection Moulding",
    description:
      "High-precision rubber moulding using both compression and injection processes. We produce complex geometries, tight tolerances, and consistent surface finishes across small and large production volumes.",
    image: "/images/image01.jpeg",
    specs: [
      "Up to 800T press force",
      "Complex multi-cavity tooling",
      "Tolerances ±0.1mm",
    ],
    tag: "Core Process",
  },
  {
    id: "02",
    title: "Rubber-to-Metal Bonding",
    description:
      "Chemically bonded rubber-metal assemblies with exceptional adhesion strength. Ideal for vibration isolation, anti-vibration mounts, bushings, and structural damping.",
    image: "/images/image02.jpeg",
    specs: [
      "Primer-based adhesion",
      "High-temperature bonding",
      "Steel, aluminium, brass",
    ],
    tag: "Speciality",
  },
  {
    id: "03",
    title: "Compound Formulation",
    description:
      "In-house compound development tailored to specific performance requirements — temperature range, chemical resistance, hardness, elongation, and ageing properties.",
    image: "/images/image03.jpeg",
    specs: [
      "7 base polymers",
      "Custom hardness 20–90 ShA",
      "RoHS & REACH compliant",
    ],
    tag: "R&D",
  },
  {
    id: "04",
    title: "Tooling & Mould Design",
    description:
      "Full in-house mould design and fabrication. Our engineering team develops optimal mould geometry for minimal flash, correct venting, and consistent dimensional stability.",
    image: "/images/AdobeStock_298672849.jpeg",
    specs: [
      "CAD/CAM design",
      "P20 & H13 tool steels",
      "Rapid prototype tooling",
    ],
    tag: "Engineering",
  },
  {
    id: "05",
    title: "Engineering Consultation",
    description:
      "Expert technical guidance from brief to production. We help clients select the right compound, optimise part design for manufacturability, and resolve challenging sealing or damping problems.",
    image: "/images/image04.jpeg",
    specs: ["Feasibility studies", "DFM analysis", "FEA-based material advice"],
    tag: "Service",
  },
  {
    id: "06",
    title: "Worldwide Shipping",
    description:
      "Reliable global logistics from our Polish facility to clients across Europe, the Americas, and Asia. Full export documentation, customs clearance support, and flexible Incoterms to match your supply chain needs.",
    image: "/images/image06.jpeg",
    specs: [
      "Air, sea & road freight",
      "EUR.1 & CoO documents",
      "40+ countries delivered",
    ],
    tag: "Logistics",
  },
];
---

<section id="capabilities" class="capabilities">
  <!-- Header -->
  <div class="cap-header container">
    <div class="cap-header-inner">
      <p class="sec-index sec-index--light reveal">02 — Capabilities</p>
      <h2 class="sec-title sec-title--light cap-title reveal reveal-delay-1">
        What we<br />
        <em>engineer</em>
      </h2>
      <p class="cap-lead reveal reveal-delay-2">
        From a raw polymer brief to a certified production component — five core
        disciplines that define TARAXA's engineering scope.
      </p>
    </div>
  </div>

  <!-- Zigzag capabilities -->
  <div class="cap-zigzag container">
    <!-- Vertical connector line -->
    <div class="cap-line" aria-hidden="true">
      <div class="cap-line-inner"></div>
    </div>

    {capabilities.map((cap, i) => (
      <article class={`cap-zig ${i % 2 !== 0 ? 'cap-zig--reverse' : ''} reveal`}>
        <!-- Image side -->
        <div class="cap-zig-img">
          <img src={cap.image} alt={cap.title} loading="lazy" />
          <div class="cap-zig-img-overlay"></div>
        </div>

        <!-- Connector dot -->
        <div class="cap-zig-dot" aria-hidden="true">
          <span class="cap-dot-ring"></span>
        </div>

        <!-- Content side -->
        <div class="cap-zig-content">
          <div class="cap-zig-meta">
            <span class="cap-num mono">{cap.id}</span>
            <span class="cap-tag mono">{cap.tag}</span>
          </div>
          <h3 class="cap-zig-title">{cap.title}</h3>
          <p class="cap-zig-desc">{cap.description}</p>
          <ul class="cap-specs">
            {cap.specs.map((s) => <li class="mono">{s}</li>)}
          </ul>
        </div>
      </article>
    ))}
  </div>

  <!-- CTA band -->
  <div class="cap-cta reveal">
    <div class="cap-cta-inner">
      <div class="cap-cta-text">
        <h3 class="heading-lg" style="color: var(--bone)">
          Have a specific requirement?
        </h3>
        <p
          class="body-sm"
          style="color: rgba(245,240,232,0.6); margin-top:0.5rem"
        >
          Tell us about your application and we will advise on the best
          approach.
        </p>
      </div>
      <a href="#contact" class="btn btn-primary btn-arrow"
        >Discuss Your Project</a
      >
    </div>
  </div>
</section>

<style>
  .capabilities {
    background: var(--ink);
    overflow: hidden;
    padding-bottom: clamp(5rem, 10vw, 9rem);
  }

  /* ── Header ── */
  .cap-header {
    padding-top: clamp(5rem, 10vw, 9rem);
    padding-bottom: clamp(3rem, 5vw, 5rem);
  }

  .cap-header-inner {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 3rem;
    row-gap: 1.25rem;
    align-items: end;
  }

  .cap-header-inner .sec-index {
    grid-column: 1 / -1;
  }
  .cap-header-inner .cap-title {
    grid-column: 1;
  }

  .cap-title em {
    color: var(--gold);
    font-style: italic;
  }

  .cap-lead {
    color: rgba(245, 240, 232, 0.5);
    font-size: clamp(0.9rem, 1.2vw, 1rem);
    line-height: 1.75;
    grid-column: 2 / 4;
    align-self: end;
  }

  /* ── Zigzag container ── */
  .cap-zigzag {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: clamp(4rem, 7vw, 6rem);
    margin-bottom: clamp(4rem, 7vw, 6rem);
  }

  /* ── Vertical connector line ── */
  .cap-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 1px;
    transform: translateX(-50%);
    z-index: 1;
  }

  .cap-line-inner {
    width: 100%;
    height: 100%;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(201, 168, 76, 0.25) 10%,
      rgba(200, 75, 47, 0.2) 50%,
      rgba(201, 168, 76, 0.25) 90%,
      transparent 100%
    );
  }

  /* ── Zigzag row ── */
  .cap-zig {
    display: grid;
    grid-template-columns: 1fr 60px 1fr;
    align-items: center;
    gap: 0;
    position: relative;
    z-index: 2;
  }

  /* Normal: image LEFT, content RIGHT */
  .cap-zig .cap-zig-img { grid-column: 1; }
  .cap-zig .cap-zig-dot { grid-column: 2; }
  .cap-zig .cap-zig-content { grid-column: 3; }

  /* Reverse: content LEFT, image RIGHT */
  .cap-zig--reverse .cap-zig-content {
    grid-column: 1;
    grid-row: 1;
  }
  .cap-zig--reverse .cap-zig-dot {
    grid-column: 2;
    grid-row: 1;
  }
  .cap-zig--reverse .cap-zig-img {
    grid-column: 3;
    grid-row: 1;
  }

  /* ── Image ── */
  .cap-zig-img {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(245, 240, 232, 0.08);
    border-radius: var(--radius-xl, 1rem);
    aspect-ratio: 16 / 10;
    transition: border-color 0.4s ease;
  }

  .cap-zig:hover .cap-zig-img {
    border-color: rgba(245, 240, 232, 0.15);
  }

  .cap-zig-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(25%) brightness(0.7);
    transition:
      transform 0.8s var(--ease-out-expo),
      filter 0.5s ease;
  }

  .cap-zig:hover .cap-zig-img img {
    transform: scale(1.04);
    filter: grayscale(0%) brightness(0.8);
  }

  .cap-zig-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 60%, rgba(28, 28, 26, 0.6) 100%);
  }

  /* ── Connector dot ── */
  .cap-zig-dot {
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
  }

  .cap-dot-ring {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid var(--rust);
    background: var(--ink);
    position: relative;
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
  }

  .cap-zig:hover .cap-dot-ring {
    border-color: var(--gold);
    box-shadow: 0 0 12px rgba(201, 168, 76, 0.35);
  }

  .cap-dot-ring::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--rust);
    transform: translate(-50%, -50%) scale(0);
    transition: transform 0.4s var(--ease-out-expo), background 0.4s ease;
  }

  .cap-zig:hover .cap-dot-ring::after {
    transform: translate(-50%, -50%) scale(1);
    background: var(--gold);
  }

  /* ── Content ── */
  .cap-zig-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem 0;
  }

  .cap-zig .cap-zig-content { padding-left: 2rem; }
  .cap-zig--reverse .cap-zig-content { padding-right: 2rem; padding-left: 0; }

  .cap-zig-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .cap-num {
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    color: rgba(245, 240, 232, 0.2);
  }

  .cap-tag {
    font-size: 0.55rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--rust);
    border: 1px solid rgba(200, 75, 47, 0.25);
    padding: 0.2rem 0.55rem;
  }

  .cap-zig-title {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.3rem, 2vw, 1.75rem);
    color: var(--bone);
    line-height: 1.15;
    letter-spacing: -0.015em;
    transition: color 0.3s ease;
  }

  .cap-zig:hover .cap-zig-title {
    color: #fff;
  }

  .cap-zig-desc {
    font-size: 0.85rem;
    color: rgba(245, 240, 232, 0.45);
    line-height: 1.75;
    max-width: 480px;
  }

  /* ── Specs ── */
  .cap-specs {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(245, 240, 232, 0.06);
    margin-top: 0.25rem;
    list-style: none;
  }

  .cap-specs li {
    font-size: 0.62rem;
    letter-spacing: 0.07em;
    color: rgba(245, 240, 232, 0.3);
    padding-left: 0.8rem;
    position: relative;
  }

  .cap-specs li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--rust);
    font-size: 0.55rem;
  }

  /* ── Scroll reveal slide-in ── */
  .cap-zig .cap-zig-img {
    opacity: 0;
    transform: translateX(-40px);
    transition: opacity 0.8s ease, transform 0.8s var(--ease-out-expo);
  }
  .cap-zig .cap-zig-content {
    opacity: 0;
    transform: translateX(40px);
    transition: opacity 0.8s ease 0.15s, transform 0.8s var(--ease-out-expo) 0.15s;
  }

  .cap-zig--reverse .cap-zig-img {
    transform: translateX(40px);
  }
  .cap-zig--reverse .cap-zig-content {
    transform: translateX(-40px);
  }

  .cap-zig.visible .cap-zig-img,
  .cap-zig.visible .cap-zig-content {
    opacity: 1;
    transform: translateX(0);
  }

  .cap-zig .cap-dot-ring {
    opacity: 0;
    transform: scale(0);
    transition: opacity 0.5s ease 0.3s, transform 0.5s var(--ease-out-expo) 0.3s;
  }

  .cap-zig.visible .cap-dot-ring {
    opacity: 1;
    transform: scale(1);
  }

  /* ── CTA band ── */
  .cap-cta {
    max-width: 1500px;
    margin: clamp(3rem, 5vw, 5rem) auto 0;
    padding-inline: var(--gutter);
  }

  .cap-cta-inner {
    background: linear-gradient(135deg, rgba(74,82,64,0.2) 0%, rgba(200,75,47,0.1) 100%);
    border: 1px solid rgba(245,240,232,0.08);
    border-radius: var(--radius-xl);
    padding: 2.5rem 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .btn-arrow::after {
    content: "→";
    display: inline-block;
    transition: transform 0.3s var(--ease-out-expo);
  }

  .btn-arrow:hover::after {
    transform: translateX(5px);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .cap-zig {
      grid-template-columns: 1fr 40px 1fr;
    }
    .cap-zig .cap-zig-content { padding-left: 1.25rem; }
    .cap-zig--reverse .cap-zig-content { padding-right: 1.25rem; }
    .cap-header-inner {
      grid-template-columns: 1fr 1fr;
    }
    .cap-lead {
      grid-column: 1 / 3;
    }
  }

  @media (max-width: 768px) {
    .cap-zigzag {
      gap: 3rem;
    }

    .cap-zig,
    .cap-zig--reverse {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .cap-zig .cap-zig-img,
    .cap-zig--reverse .cap-zig-img {
      grid-column: 1;
      grid-row: 1;
    }
    .cap-zig .cap-zig-content,
    .cap-zig--reverse .cap-zig-content {
      grid-column: 1;
      grid-row: 2;
      padding-left: 0;
      padding-right: 0;
    }

    .cap-zig-dot,
    .cap-line {
      display: none;
    }

    .cap-zig .cap-zig-img,
    .cap-zig--reverse .cap-zig-img {
      transform: translateY(20px);
    }
    .cap-zig .cap-zig-content,
    .cap-zig--reverse .cap-zig-content {
      transform: translateY(20px);
    }
    .cap-zig.visible .cap-zig-img,
    .cap-zig.visible .cap-zig-content {
      transform: translateY(0);
    }

    .cap-header-inner {
      grid-template-columns: 1fr;
    }
    .cap-lead {
      grid-column: 1;
    }
    .cap-cta-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
