---
const materials = [
  {
    id: 'EPDM',
    fullName: 'Ethylene Propylene Diene Monomer',
    color: '#4A5240',
    bgColor: 'rgba(74,82,64,0.08)',
    borderColor: 'rgba(74,82,64,0.2)',
    hardnessRange: '30–90 ShA',
    tempRange: '-50°C to +150°C',
    tags: ['Weathering', 'UV & ozone', 'Steam', 'Outdoor use'],
    applications: ['Automotive seals', 'Roofing membranes', 'HVAC gaskets', 'Railway profiles'],
    strengths: ['Outstanding weather resistance', 'Excellent steam & hot water resistance', 'Good electrical insulation'],
    description: 'The workhorse of outdoor rubber applications. EPDM\'s saturated backbone provides exceptional UV and ozone resistance, making it the default choice for exterior sealing and waterproofing.',
    image: '/images/AdobeStock_200327947.jpeg',
  },
  {
    id: 'NBR',
    fullName: 'Nitrile Butadiene Rubber',
    color: '#C84B2F',
    bgColor: 'rgba(200,75,47,0.08)',
    borderColor: 'rgba(200,75,47,0.25)',
    hardnessRange: '30–85 ShA',
    tempRange: '-40°C to +120°C',
    tags: ['Oil & fuel', 'Hydraulics', 'Industrial'],
    applications: ['O-rings', 'Hydraulic seals', 'Fuel hoses', 'Engine mounts'],
    strengths: ['Superior oil and fuel resistance', 'Good abrasion resistance', 'Wide hardness range'],
    description: 'The industry standard for oil-contact applications. NBR\'s acrylonitrile content can be tuned for the precise balance of fuel resistance and low-temperature flexibility your application demands.',
    image: '/images/AdobeStock_216053278.jpeg',
  },
  {
    id: 'CR',
    fullName: 'Chloroprene (Neoprene)',
    color: '#1A1A18',
    bgColor: 'rgba(26,26,24,0.05)',
    borderColor: 'rgba(26,26,24,0.15)',
    hardnessRange: '35–80 ShA',
    tempRange: '-40°C to +120°C',
    tags: ['Flame retardant', 'Oil resistant', 'Marine'],
    applications: ['Wetsuits', 'Cable insulation', 'Vibration mounts', 'Chemical hoses'],
    strengths: ['Self-extinguishing properties', 'Good oil and chemical resistance', 'Balanced mechanical properties'],
    description: 'Neoprene sits at the intersection of mechanical performance and chemical resistance. Its inherent flame retardancy makes it valuable in demanding electrical and industrial environments.',
    image: '/images/AdobeStock_429597067.jpeg',
  },
  {
    id: 'VMQ',
    fullName: 'Silicone (Vinyl Methyl Silicone)',
    color: '#8a6d28',
    bgColor: 'rgba(201,168,76,0.08)',
    borderColor: 'rgba(201,168,76,0.3)',
    hardnessRange: '20–80 ShA',
    tempRange: '-60°C to +200°C',
    tags: ['High temp', 'Food-grade', 'Medical'],
    applications: ['Oven seals', 'Medical devices', 'Aerospace gaskets', 'LED encapsulation'],
    strengths: ['Extreme temperature range', 'Biocompatible grades available', 'Excellent electrical properties'],
    description: 'Where temperature extremes meet purity requirements. Silicone\'s inorganic backbone enables performance across a 260°C operating window, with FDA and USP Class VI compliant grades available.',
    image: '/images/AdobeStock_1796601640.jpeg',
  },
  {
    id: 'FKM',
    fullName: 'Fluoelastomer (Viton®)',
    color: '#C84B2F',
    bgColor: 'rgba(200,75,47,0.06)',
    borderColor: 'rgba(200,75,47,0.2)',
    hardnessRange: '55–90 ShA',
    tempRange: '-20°C to +230°C',
    tags: ['Aggressive chemicals', 'High performance', 'Aerospace'],
    applications: ['Chemical plant seals', 'Aerospace O-rings', 'Engine seals', 'Hydraulic systems'],
    strengths: ['Highest chemical resistance of any elastomer', 'Outstanding high-temperature stability', 'Low permeability to gases'],
    description: 'The premium choice for aggressive chemical environments. FKM withstands concentrated acids, fuels, and aromatic solvents that would rapidly degrade standard elastomers.',
    image: '/images/AdobeStock_1827798751.jpeg',
  },
  {
    id: 'NR',
    fullName: 'Natural Rubber',
    color: '#4A5240',
    bgColor: 'rgba(74,82,64,0.06)',
    borderColor: 'rgba(74,82,64,0.18)',
    hardnessRange: '20–90 ShA',
    tempRange: '-55°C to +80°C',
    tags: ['Vibration', 'High tensile', 'Dynamic loading'],
    applications: ['Bridge bearings', 'Anti-vibration mounts', 'Seismic isolators', 'Agricultural machinery'],
    strengths: ['Highest tensile strength of natural polymers', 'Exceptional tear resistance', 'Superior dynamic fatigue life'],
    description: 'The original elastomer — still unmatched for dynamic applications requiring the highest energy return and fatigue resistance. The compound from which TARAXA takes its botanical identity.',
    image: '/images/AdobeStock_739695915.jpeg',
  },
  {
    id: 'SBR',
    fullName: 'Styrene Butadiene Rubber',
    color: '#1A1A18',
    bgColor: 'rgba(26,26,24,0.04)',
    borderColor: 'rgba(26,26,24,0.12)',
    hardnessRange: '40–80 ShA',
    tempRange: '-40°C to +100°C',
    tags: ['Abrasion', 'General purpose', 'Cost-effective'],
    applications: ['Conveyor belts', 'Floor matting', 'Shoe soles', 'General sealing'],
    strengths: ['Excellent abrasion resistance', 'Good aging properties when compounded', 'Cost-effective for high volume'],
    description: 'The high-volume workhorse. SBR\'s excellent abrasion resistance and favourable cost profile make it the rational choice for wear surfaces, flooring, and general industrial sealing.',
    image: '/images/AdobeStock_75169017.jpeg',
  },
];
---

<section id="materials" class="materials">
  <div class="container">

    <!-- Header -->
    <div class="mat-header">
      <div class="mat-header-content reveal reveal-delay-1">
        <p class="sec-index reveal">04 — Materials</p>
        <h2 class="sec-title mat-title">
          Seven polymers.<br/>
          <em>Infinite possibilities.</em>
        </h2>
        <p class="body-lg mat-lead">
          Our compound library spans the full spectrum of elastomeric performance.
          Every formulation is optimised in-house for your specific temperature,
          chemical, and mechanical requirements.
        </p>
      </div>
    </div>

    <!-- Tab nav -->
    <div class="mat-tabs" role="tablist" aria-label="Rubber materials">
      {materials.map((mat, i) => (
        <button
          class={`mat-tab ${i === 0 ? 'active' : ''}`}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-controls={`mat-panel-${mat.id}`}
          id={`mat-tab-${mat.id}`}
          data-mat={mat.id}
        >
          <span class="mat-tab-id mono">{mat.id}</span>
        </button>
      ))}
    </div>

    <!-- Panels -->
    <div class="mat-panels">
      {materials.map((mat, i) => (
        <div
          class={`mat-panel ${i === 0 ? 'active' : ''}`}
          role="tabpanel"
          id={`mat-panel-${mat.id}`}
          aria-labelledby={`mat-tab-${mat.id}`}
          data-mat={mat.id}
        >
          <div class="mat-panel-grid">
            <!-- Left: info -->
            <div class="mat-panel-info">
              <div class="mat-panel-header">
                <div class="mat-panel-id" style={`color: ${mat.color};`}>{mat.id}</div>
                <div>
                  <p class="mat-full-name mono">{mat.fullName}</p>
                </div>
              </div>

              <p class="body-lg mat-desc">{mat.description}</p>

              <div class="mat-tags">
                {mat.tags.map(tag => (
                  <span class="label mat-tag">{tag}</span>
                ))}
              </div>

              <div class="mat-specs-grid">
                <div class="mat-spec">
                  <span class="mat-spec-label mono">Hardness Range</span>
                  <span class="mat-spec-val">{mat.hardnessRange}</span>
                </div>
                <div class="mat-spec">
                  <span class="mat-spec-label mono">Temperature</span>
                  <span class="mat-spec-val">{mat.tempRange}</span>
                </div>
              </div>

              <div class="mat-panel-cols">
                <div class="mat-col">
                  <p class="mono mat-col-head">Key Strengths</p>
                  <ul class="mat-list">
                    {mat.strengths.map(s => (
                      <li>
                        <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                          <path d="M2 5l2.5 2.5L8 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        {s}
                      </li>
                    ))}
                  </ul>
                </div>
                <div class="mat-col">
                  <p class="mono mat-col-head">Applications</p>
                  <ul class="mat-list">
                    {mat.applications.map(a => (
                      <li>
                        <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                          <circle cx="5" cy="5" r="2" fill="currentColor"/>
                        </svg>
                        {a}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <a href="#contact" class="btn btn-outline-dark mat-cta">
                Request {mat.id} Samples
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>

            <!-- Right: image -->
            <div class="mat-panel-image">
              <div class="mat-img-wrap">
                <img
                  src={mat.image}
                  alt={`${mat.id} rubber compound — ${mat.fullName}`}
                  loading="lazy"
                  width="600"
                  height="700"
                />
                <div class="mat-img-overlay" style={`background: linear-gradient(135deg, ${mat.color}22 0%, transparent 60%)`}></div>
              </div>

              <!-- Hardness scale visual -->
              <div class="mat-hardness-bar">
                <span class="mono" style="font-size:0.62rem; color: var(--ink-60)">Shore A Hardness</span>
                <div class="mat-bar-track">
                  <div
                    class="mat-bar-fill"
                    style={`background: ${mat.color}; width: ${(parseInt(mat.hardnessRange) / 90) * 100}%`}
                  ></div>
                </div>
                <div class="mat-bar-labels">
                  <span class="mono">20</span>
                  <span class="mono">{mat.hardnessRange}</span>
                  <span class="mono">90</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .materials {
    background: var(--bone);
    padding-block: clamp(5rem, 10vw, 9rem);
    overflow: hidden;
  }

  /* Header */
  .mat-header {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 4rem;
    align-items: end;
    margin-bottom: 3.5rem;
  }

  .mat-header-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .mat-title {
    font-family: var(--font-display);
    color: var(--ink);
    flex-shrink: 0;
  }

  .mat-title em { color: var(--moss); font-style: italic; }

  .mat-lead {
    color: var(--ink-60);
    max-width: 380px;
    font-size: clamp(0.95rem, 1.2vw, 1.1rem);
    line-height: 1.7;
  }

  /* Tabs */
  .mat-tabs {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--ink-10);
  }

  .mat-tab {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    border-radius: 100px;
    border: 1.5px solid var(--ink-10);
    background: transparent;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .mat-tab:hover {
    border-color: var(--ink-30);
    background: rgba(26,26,24,0.04);
  }

  .mat-tab.active {
    background: var(--ink);
    border-color: var(--ink);
  }

  .mat-tab-id {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--ink-60);
    transition: color 0.25s ease;
  }

  .mat-tab.active .mat-tab-id {
    color: var(--bone);
  }

  /* Panels */
  .mat-panel {
    display: none;
    animation: mat-panel-in 0.4s var(--ease-out-expo);
  }

  .mat-panel.active { display: block; }

  @keyframes mat-panel-in {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .mat-panel-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2.5rem, 5vw, 5rem);
    align-items: start;
  }

  /* Info */
  .mat-panel-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .mat-panel-id {
    font-family: var(--font-display);
    font-size: clamp(3rem, 5vw, 5rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .mat-full-name {
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    color: var(--ink-60);
    text-transform: uppercase;
  }

  .mat-desc {
    color: var(--ink);
    margin-bottom: 1.5rem;
    font-size: clamp(1rem, 1.2vw, 1.1rem);
    line-height: 1.75;
  }

  .mat-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 2rem;
  }

  .mat-tag {
    font-size: 0.68rem;
  }

  .mat-specs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 2rem;
    padding: 1.25rem;
    background: rgba(26,26,24,0.04);
    border-radius: var(--radius-md);
    border: 1px solid var(--ink-10);
  }

  .mat-spec-label {
    display: block;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-30);
    margin-bottom: 0.3rem;
  }

  .mat-spec-val {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .mat-panel-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .mat-col-head {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-30);
    margin-bottom: 0.75rem;
  }

  .mat-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mat-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--ink-60);
    line-height: 1.5;
  }

  .mat-list li svg {
    flex-shrink: 0;
    margin-top: 3px;
    color: var(--moss);
  }

  .mat-cta {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    padding: 0.7rem 1.5rem;
  }

  /* Image */
  .mat-panel-image {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 6rem;
  }

  .mat-img-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
    box-shadow: 0 20px 60px rgba(26,26,24,0.12);
  }

  .mat-img-wrap img {
    width: 100%;
    height: 440px;
    object-fit: cover;
    transition: transform 0.7s var(--ease-out-expo);
  }

  .mat-img-wrap:hover img { transform: scale(1.03); }

  .mat-img-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  /* Hardness bar */
  .mat-hardness-bar {
    padding: 1.25rem;
    background: rgba(26,26,24,0.04);
    border-radius: var(--radius-md);
    border: 1px solid var(--ink-10);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mat-bar-track {
    width: 100%;
    height: 4px;
    background: var(--ink-10);
    border-radius: 4px;
    overflow: hidden;
  }

  .mat-bar-fill {
    height: 100%;
    border-radius: 4px;
    opacity: 0.7;
    transition: width 0.6s var(--ease-out-expo);
  }

  .mat-bar-labels {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--ink-30);
    letter-spacing: 0.08em;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .mat-panel-grid { grid-template-columns: 1fr; }
    .mat-panel-image { position: static; }
    .mat-img-wrap img { height: 320px; }
    .mat-header { grid-template-columns: 1fr; gap: 1.5rem; }
    .mat-header-content { flex-direction: column; align-items: flex-start; gap: 1rem; }
  }

  @media (max-width: 640px) {
    .mat-panel-cols { grid-template-columns: 1fr; }
    .mat-specs-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Tab switching
  const tabs = document.querySelectorAll('.mat-tab');
  const panels = document.querySelectorAll('.mat-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const matId = tab.getAttribute('data-mat');

      tabs.forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      panels.forEach(p => p.classList.remove('active'));

      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');

      const panel = document.querySelector(`.mat-panel[data-mat="${matId}"]`);
      if (panel) panel.classList.add('active');
    });
  });

  // Keyboard navigation
  tabs.forEach((tab, i) => {
    tab.addEventListener('keydown', (e) => {
      const ke = e as KeyboardEvent;
      if (ke.key === 'ArrowRight') {
        const next = (tabs[i + 1] || tabs[0]) as HTMLElement;
        next.focus();
        next.click();
      }
      if (ke.key === 'ArrowLeft') {
        const prev = (tabs[i - 1] || tabs[tabs.length - 1]) as HTMLElement;
        prev.focus();
        prev.click();
      }
    });
  });
</script>
